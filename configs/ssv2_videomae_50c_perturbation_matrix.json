{
  "matrix_name": "ssv2_50c_train100_val30_videomae_base_16f_perturbation_matrix",
  "report_basename": "ssv2_50c_train100_val30_videomae_base_16f",
  "dataset_name": "ssv2",
  "model_checkpoint": "MCG-NJU/videomae-base",
  "embedding_type": "last_hidden_state_mean_pool",
  "num_frames": 16,
  "sampling_strategy": "deterministic_center_clip",
  "image_size": 224,
  "scope": {
    "train_reference_artifact": "outputs/embeddings/train_original.pt",
    "validation_original_artifact": "outputs/embeddings/validation_original.pt",
    "validation_index_path": "data/ssv2/index/validation.jsonl",
    "apply_perturbations_to_split": "validation",
    "train_reference_perturbation": "none",
    "accuracy_drop_baseline_report": "outputs/logs/ssv2_50c_train100_val30_videomae_base_16f_original_baseline_interpretability.json",
    "primary_knn_metric": "cosine",
    "knn_k_values": [
      1,
      5,
      10
    ],
    "report_all_validation_accuracy": true,
    "report_train_seen_only_accuracy": true
  },
  "first_round": [
    {
      "name": "temporal_reverse",
      "group": "motion",
      "default_parameters": {
        "seed": 0,
        "frame_index": null,
        "freeze_start_fraction": 0.5,
        "occlusion_size_fraction": 0.25,
        "occlusion_fill_value": 0
      },
      "output_path": "outputs/embeddings/validation_temporal_reverse.pt",
      "primary_disrupted_information": [
        "temporal order",
        "motion direction"
      ],
      "secondary_effects": [
        "can make causally asymmetric actions physically implausible",
        "does not remove per-frame appearance cues"
      ]
    },
    {
      "name": "temporal_shuffle",
      "group": "motion",
      "default_parameters": {
        "seed": 0,
        "frame_index": null,
        "freeze_start_fraction": 0.5,
        "occlusion_size_fraction": 0.25,
        "occlusion_fill_value": 0
      },
      "output_path": "outputs/embeddings/validation_temporal_shuffle.pt",
      "primary_disrupted_information": [
        "temporal order",
        "short-range motion continuity"
      ],
      "secondary_effects": [
        "keeps the same sampled frames but creates unnatural transitions",
        "seed controls deterministic per-video frame order"
      ]
    },
    {
      "name": "freeze_tail",
      "group": "motion",
      "default_parameters": {
        "seed": 0,
        "frame_index": null,
        "freeze_start_fraction": 0.5,
        "occlusion_size_fraction": 0.25,
        "occlusion_fill_value": 0
      },
      "output_path": "outputs/embeddings/validation_freeze_tail.pt",
      "primary_disrupted_information": [
        "late temporal dynamics",
        "motion completion"
      ],
      "secondary_effects": [
        "preserves early clip appearance",
        "changes temporal redundancy after the freeze point"
      ]
    },
    {
      "name": "single_frame",
      "group": "motion",
      "default_parameters": {
        "seed": 0,
        "frame_index": null,
        "frame_position": "center",
        "freeze_start_fraction": 0.5,
        "occlusion_size_fraction": 0.25,
        "occlusion_fill_value": 0
      },
      "output_path": "outputs/embeddings/validation_single_frame.pt",
      "primary_disrupted_information": [
        "all temporal dynamics",
        "motion trajectory"
      ],
      "secondary_effects": [
        "retains one frame of static object and scene appearance",
        "strongly increases temporal redundancy"
      ]
    },
    {
      "name": "grayscale",
      "group": "appearance",
      "default_parameters": {
        "seed": 0,
        "frame_index": null,
        "freeze_start_fraction": 0.5,
        "occlusion_size_fraction": 0.25,
        "occlusion_fill_value": 0
      },
      "output_path": "outputs/embeddings/validation_grayscale.pt",
      "primary_disrupted_information": [
        "color appearance"
      ],
      "secondary_effects": [
        "preserves shape, texture contrast, and temporal order",
        "may affect models that use color statistics for normalization-sensitive cues"
      ]
    },
    {
      "name": "center_occlusion",
      "group": "appearance",
      "default_parameters": {
        "seed": 0,
        "frame_index": null,
        "freeze_start_fraction": 0.5,
        "occlusion_size_fraction": 0.25,
        "occlusion_fill_value": 0
      },
      "output_path": "outputs/embeddings/validation_center_occlusion.pt",
      "primary_disrupted_information": [
        "central spatial appearance",
        "object visibility"
      ],
      "secondary_effects": [
        "may hide hands or manipulated objects",
        "can also remove local motion evidence inside the occluded region"
      ]
    }
  ],
  "sweeps": [
    {
      "sweep_name": "freeze_tail_start_fraction",
      "base_perturbation": "freeze_tail",
      "group": "motion",
      "parameter": "freeze_start_fraction",
      "values": [
        0.25,
        0.5,
        0.75
      ],
      "output_path_template": "outputs/embeddings/validation_freeze_tail_start-{value}.pt",
      "interpretation": "Smaller values freeze more of the clip and should be treated as stronger temporal disruption."
    },
    {
      "sweep_name": "center_occlusion_size_fraction",
      "base_perturbation": "center_occlusion",
      "group": "appearance",
      "parameter": "occlusion_size_fraction",
      "values": [
        0.15,
        0.25,
        0.4
      ],
      "output_path_template": "outputs/embeddings/validation_center_occlusion_size-{value}.pt",
      "interpretation": "Larger values remove more central spatial information."
    },
    {
      "sweep_name": "single_frame_position",
      "base_perturbation": "single_frame",
      "group": "motion",
      "parameter": "frame_index",
      "values": [
        {
          "label": "first",
          "value": 0
        },
        {
          "label": "center",
          "value": null
        },
        {
          "label": "last",
          "value": 15
        }
      ],
      "output_path_template": "outputs/embeddings/validation_single_frame_{label}.pt",
      "interpretation": "Frame position controls which static state remains after all motion is removed."
    },
    {
      "sweep_name": "temporal_shuffle_seed_repeat",
      "base_perturbation": "temporal_shuffle",
      "group": "motion",
      "parameter": "seed",
      "values": [
        0,
        1,
        2
      ],
      "output_path_template": "outputs/embeddings/validation_temporal_shuffle_seed-{value}.pt",
      "interpretation": "Seed repeats estimate whether shuffle sensitivity is stable across different deterministic frame orders."
    }
  ]
}
